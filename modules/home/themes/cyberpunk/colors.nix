# Cyberpunk 2077 Color Palette
# Based on the game's UI design and Night City aesthetics

{
  # Primary colors - Core cyberpunk neons
  primary = {
    cyan = "#00f5ff";        # Electric cyan
    magenta = "#ff0080";     # Hot magenta
    yellow = "#ffff00";      # Neon yellow
    purple = "#8a2be2";      # Deep purple
  };

  # Secondary colors - Supporting tones
  secondary = {
    teal = "#00d4aa";        # Cyberpunk teal
    green = "#00d4aa";       # Same as teal for consistency
    pink = "#ff006e";        # Neon pink  
    orange = "#ff9500";      # Warning orange
    violet = "#6a0dad";      # Royal violet
    blue = "#0080ff";        # Electric blue
  };

  # Background colors - Dark tech bases
  background = {
    darkest = "#0a0a0a";     # Pure dark
    dark = "#1a1a1a";        # Dark grey
    medium = "#2a2a2a";      # Medium grey
    tech = "#0d1117";        # GitHub dark
    light_purple = "#1a1625"; # Very light purple background
    light_blue = "#151a25";   # Very light blue background
  };

  # Text colors - Readability with style
  text = {
    primary = "#e4e4e7";     # Light grey
    secondary = "#a1a1aa";   # Medium grey
    disabled = "#4a4a4a";    # Grey disabled
    accent = "#00f5ff";      # Cyan accent
    warning = "#ff9500";     # Orange warning
    error = "#ff006e";       # Pink error
    success = "#00d4aa";     # Teal success
  };

  # UI elements - Interface components
  ui = {
    background = "#1a1a1a";       # Main background
    surface = "#2a2a2a";          # Surface elements
    border_active = "#00f5ff";    # Cyan borders
    border_inactive = "#2a2a2a";  # Dark borders
    hover = "#ff008080";          # Magenta hover
    selected = "#8a2be280";       # Purple selected
    disabled = "#4a4a4a";         # Grey disabled
  };

  # Special effects - Glow and transparency
  effects = {
    glow_cyan = "#00f5ff80";      # Cyan glow
    glow_magenta = "#ff008080";   # Magenta glow
    glow_yellow = "#ffff0080";    # Yellow glow
    shadow = "#00000080";         # Black shadow
    overlay = "#1a1a1a80";        # Dark overlay
  };

  # Status colors - System states
  status = {
    success = "#00d4aa";     # Teal success
    warning = "#ff9500";     # Orange warning
    error = "#ff006e";       # Pink error
    info = "#00f5ff";        # Cyan info
  };

  # Terminal colors - 16-color palette
  terminal = {
    black = "#1a1a1a";
    red = "#ff006e";
    green = "#00d4aa";
    yellow = "#ffff00";
    blue = "#00f5ff";
    magenta = "#ff0080";
    cyan = "#00d4aa";
    white = "#e4e4e7";
    bright_black = "#4a4a4a";
    bright_red = "#ff4da6";
    bright_green = "#4dffdb";
    bright_yellow = "#ffff4d";
    bright_blue = "#4df8ff";
    bright_magenta = "#ff4db3";
    bright_cyan = "#4dffdb";
    bright_white = "#ffffff";
  };
}